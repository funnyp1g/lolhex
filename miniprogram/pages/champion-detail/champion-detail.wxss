/* pages/champion-detail/champion-detail.wxss - 英雄详情样式 */
.page-champion-detail {
  padding: var(--spacing-md);
  padding-bottom: calc(var(--spacing-xxl) + env(safe-area-inset-bottom));
  min-height: 100vh;
  background-color: var(--color-bg-page);
}

/* ===== 英雄头部 ===== */
.hero-header {
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-lg);
  background-color: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  box-shadow: var(--shadow-sm);
  margin-bottom: var(--spacing-md);
}

.hero-avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.hero-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-lg);
  background-color: var(--color-bg-page);
}

.hero-tier {
  position: absolute;
  bottom: -8rpx;
  right: -8rpx;
}

.hero-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.hero-name {
  font-size: var(--font-size-title);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}

.hero-title {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.hero-roles {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: var(--spacing-sm);
}

.hero-role-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-round);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  line-height: 1.4;
  text-align: center;
  vertical-align: middle;
}

/* 英雄卡片内联胜率/选取率 */
.hero-inline-stats {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-top: var(--spacing-sm);
  padding-top: var(--spacing-sm);
  border-top: 1rpx solid var(--color-border-light, #f0f0f0);
}

.hero-inline-stat {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
}

.hero-inline-stat.winrate {
  color: var(--color-warning);
}

.hero-inline-stat.pickrate {
  color: var(--color-primary);
}

.hero-inline-stat-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-placeholder);
  margin-right: 8rpx;
}

.hero-inline-stat-divider {
  color: var(--color-border);
  margin: 0 4rpx;
}

/* ===== 通用区块 ===== */
.section {
  margin-bottom: var(--spacing-lg);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.section-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}

.empty-hint {
  padding: var(--spacing-xl) 0;
}

.aug-list {
  /* 列表容器 */
}

/* ===== 装备区块 ===== */
.item-group {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
}

.item-group-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-md);
}

.item-group-count {
  font-size: var(--font-size-xs);
  color: var(--color-text-placeholder);
  font-weight: var(--font-weight-normal);
}

/* 装备网格 */
.item-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-md);
}

.item-grid-cell {
  width: calc(25% - 18rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.item-grid-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-md);
  background-color: var(--color-bg-page);
}

.item-grid-name {
  font-size: var(--font-size-xs);
  color: var(--color-text-primary);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.item-grid-rate {
  font-size: 18rpx;
  color: var(--color-warning);
  font-weight: var(--font-weight-medium);
}

/* ===== 装备配置-流派（aramgg 1:1 复刻） ===== */
.build-group {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
}

.build-group-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
  padding-bottom: var(--spacing-sm);
  border-bottom: 1rpx solid var(--color-border-light);
}

.build-group-tags {
  display: flex;
  gap: 8rpx;
}

.build-tag {
  font-size: 20rpx;
  font-weight: var(--font-weight-bold);
  padding: 2rpx 14rpx;
  border-radius: 6rpx;
  color: #fff;
  background: #555;
}

.build-tag-AP { background: #7c3aed; }
.build-tag-AD { background: #dc2626; }
.build-tag-Tank { background: #059669; }
.build-tag-Bruiser { background: #d97706; }
.build-tag-Crit { background: #db2777; }
.build-tag-On-Hit { background: #0891b2; }
.build-tag-Support { background: #4f46e5; }
.build-tag-Assassin { background: #e11d48; }

.build-group-meta {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.build-meta-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.build-meta-text.winrate {
  color: var(--color-warning);
  font-weight: var(--font-weight-medium);
}

.build-meta-sep {
  font-size: var(--font-size-xs);
  color: var(--color-border);
}

/* ===== 核心装备卡片（大图+底部名称） ===== */
.core-builds-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

.core-build-card {
  background: var(--color-bg-page);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
}

.core-build-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-sm);
}

.core-build-rank {
  font-size: 24rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

.core-build-winrate {
  font-size: 22rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-warning);
}

/* 大图3列布局 */
.core-build-icons-lg {
  display: flex;
  gap: var(--spacing-sm);
}

.core-build-item-lg {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.core-build-icon-lg {
  width: 104rpx;
  height: 104rpx;
  border-radius: var(--radius-md);
  background-color: #1a1a2e;
}

.core-build-name-lg {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

/* 出门装行 */
.simple-item-row {
  display: flex;
  gap: var(--spacing-md);
  flex-wrap: wrap;
  padding: var(--spacing-xs) 0;
}

.simple-item-cell {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 16rpx 6rpx 8rpx;
  background: var(--color-bg-page);
  border-radius: 8rpx;
}

.simple-item-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 4rpx;
  background-color: #1a1a2e;
}

.simple-item-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

/* 备选装备网格 */
.item-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-md);
}

.item-grid-cell {
  width: calc(25% - 18rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.item-grid-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-md);
  background-color: #1a1a2e;
}

.item-grid-name {
  font-size: 18rpx;
  color: var(--color-text-secondary);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

/* 神装行 */
.fullbuild-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.fullbuild-row {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  padding: var(--spacing-sm) 0;
  border-bottom: 1rpx solid var(--color-border-light);
}

.fullbuild-row:last-child {
  border-bottom: none;
}

.fullbuild-items {
  display: flex;
  gap: 8rpx;
}

.fullbuild-item-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-base);
  background-color: var(--color-bg-page);
}

.fullbuild-item-icon-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.fullbuild-info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}

.fullbuild-winrate {
  font-size: var(--font-size-sm);
  color: var(--color-warning);
  font-weight: var(--font-weight-medium);
}

/* ===== 海克斯展开/收起按钮 ===== */
.aug-expand-wrap {
  display: flex;
  justify-content: center;
  padding: var(--spacing-md) 0;
}

.aug-expand-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  background: var(--color-bg-page);
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  transition: background-color var(--transition-fast);
}

.aug-expand-btn:active {
  background: var(--color-bg-hover);
}

.aug-expand-arrow {
  font-size: var(--font-size-xs);
  transition: transform var(--transition-base);
}

.aug-expand-arrow.expanded {
  transform: rotate(180deg);
}

/* 重试按钮 */
.retry-btn {
  margin-top: var(--spacing-md);
}

/* 阶段表现副标题 */
.section-subtitle {
  font-size: var(--font-size-xs);
  color: var(--color-text-placeholder);
}

/* 错误状态 */
.error-state {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 50vh;
}
