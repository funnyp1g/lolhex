<!--pages/index/index.wxml - 首页-->
<view class="page-index">
  <!-- 加载中 -->
  <loading-skeleton wx:if="{{loading}}" type="augment" count="{{4}}" />

  <!-- 错误状态 -->
  <view wx:elif="{{error}}" class="error-state">
    <van-empty description="数据加载失败" image="error">
      <van-button round type="danger" class="retry-btn" bindtap="onRetry">重新加载</van-button>
    </van-empty>
  </view>

  <!-- 加载完成 -->
  <block wx:elif="{{!loading}}">
    <!-- ===== 版本调整卡片 ===== -->
    <view class="patch-card card" bindtap="toggleAdjustmentsDetail">
      <view class="patch-header">
        <view class="patch-title-row">
          <text class="patch-title">版本调整</text>
          <!-- 调整摘要 -->
          <view wx:if="{{patchAdjustments}}" class="patch-summary">
            <text class="patch-buff-count">📈 {{patchAdjustments.buffs.length}}项增强</text>
            <text class="patch-nerf-count">📉 {{patchAdjustments.nerfs.length}}项削弱</text>
            <view wx:if="{{patchAdjustments.balance.length > 0}}" class="patch-balance-count">
              🔄 {{patchAdjustments.balance.length}}项调整
            </view>
          </view>
          <text wx:else class="patch-summary-placeholder">暂无调整数据</text>
        </view>
        <view class="patch-right">
          <text class="expand-arrow {{showAdjustmentsDetail ? 'expanded' : ''}}">▼</text>
        </view>
      </view>

      <!-- 调整详情（展开） -->
      <view wx:if="{{showAdjustmentsDetail && patchAdjustments}}" class="patch-detail">
        <!-- 增强 -->
        <view wx:if="{{patchAdjustments.buffs.length > 0}}" class="detail-group">
          <view class="detail-group-title detail-group-title-buff">
            📈 增强
          </view>
          <view
            wx:for="{{patchAdjustments.buffs}}"
            wx:key="name"
            class="detail-item"
          >
            <text class="detail-item-name">{{item.name}}</text>
            <text class="detail-item-desc">{{item.desc}}</text>
          </view>
        </view>

        <!-- 削弱 -->
        <view wx:if="{{patchAdjustments.nerfs.length > 0}}" class="detail-group">
          <view class="detail-group-title detail-group-title-nerf">
            📉 削弱
          </view>
          <view
            wx:for="{{patchAdjustments.nerfs}}"
            wx:key="name"
            class="detail-item"
          >
            <text class="detail-item-name">{{item.name}}</text>
            <text class="detail-item-desc">{{item.desc}}</text>
          </view>
        </view>

        <!-- 平衡 -->
        <view wx:if="{{patchAdjustments.balance.length > 0}}" class="detail-group">
          <view class="detail-group-title detail-group-title-balance">
            🔄 平衡调整
          </view>
          <view
            wx:for="{{patchAdjustments.balance}}"
            wx:key="name"
            class="detail-item"
          >
            <text class="detail-item-name">{{item.name}}</text>
            <text class="detail-item-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 🔍 搜索栏 -->
    <view class="home-search-wrap" bindtap="onSearchTap">
      <view class="home-search-inner">
        <text class="home-search-icon">🔍</text>
        <text class="home-search-placeholder">搜索英雄 / 海克斯...</text>
      </view>
    </view>

    <!-- 🏆 英雄强度排行 + ⚡ 海克斯排行（双栏） -->
    <view class="section">
      <view class="dual-panel">
        <!-- 左栏：英雄排行 -->
        <view class="dual-panel-item dual-panel-left">
          <view class="section-header">
            <text class="section-title">🏆 英雄排行</text>
            <text class="section-more" bindtap="onGoChampionList">全部 ›</text>
          </view>
          <view wx:if="{{champRankList.length === 0 && !champRankLoading}}" class="empty-mini">
            <text class="text-xs text-secondary">暂无数据</text>
          </view>
          <view wx:else class="mini-rank-list">
            <view
              wx:for="{{champRankList}}"
              wx:key="champion_id"
              class="mini-rank-item"
              data-champion-id="{{item.champion_id}}"
              bindtap="onMiniChampionTap"
            >
              <text class="mini-rank-index">{{index + 1}}</text>
              <image wx:if="{{item.icon_url}}" class="mini-rank-icon" src="{{item.icon_url}}" mode="aspectFill" />
              <view wx:else class="mini-rank-icon mini-rank-icon-empty"></view>
              <view class="mini-rank-info">
                <text class="mini-rank-name ellipsis">{{item.name_zh || item.name}}</text>
                <text class="mini-rank-winrate">{{item.win_rate}}%</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 右栏：海克斯排行 -->
        <view class="dual-panel-item dual-panel-right">
          <view class="section-header">
            <text class="section-title">⚡ 海克斯排行</text>
            <text class="section-more" bindtap="onGoAugmentList">全部 ›</text>
          </view>
          <view wx:if="{{augRankList.length === 0 && !augRankLoading}}" class="empty-mini">
            <text class="text-xs text-secondary">暂无数据</text>
          </view>
          <view wx:else class="mini-rank-list">
            <view
              wx:for="{{augRankList}}"
              wx:key="riot_id"
              class="mini-rank-item"
              data-id="{{item.riot_id || item._id}}"
              bindtap="onMiniAugmentTap"
            >
              <text class="mini-rank-index">{{index + 1}}</text>
              <image wx:if="{{item.icon_url}}" class="mini-rank-icon" src="{{item.icon_url}}" mode="aspectFill" />
              <view wx:else class="mini-rank-icon mini-rank-icon-empty"></view>
              <view class="mini-rank-info">
                <text class="mini-rank-name ellipsis">{{item.name_zh || item.name}}</text>
                <text class="mini-rank-winrate">{{item.win_rate}}%</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 🔥 热门搭配 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">🔥 热门搭配</text>
        <text class="section-subtitle">最强英雄 + 海克斯 + 装备组合</text>
      </view>
      <view wx:if="{{hotCombos.length === 0 && !comboLoading}}" class="empty-mini">
        <text class="text-xs text-secondary">暂无数据</text>
      </view>
      <view wx:else class="combo-list">
        <view
          wx:for="{{hotCombos}}"
          wx:key="combo_id"
          class="combo-card"
          data-champion-id="{{item.champion_id}}"
          bindtap="onComboTap"
        >
          <!-- 排名徽章 -->
          <view class="combo-rank-badge combo-rank-{{index < 3 ? (index === 0 ? 'gold' : index === 1 ? 'silver' : 'bronze') : 'normal'}}">
            <text class="combo-rank-num">{{index + 1}}</text>
          </view>

          <!-- 卡片主体 -->
          <view class="combo-card-body">
            <!-- 英雄头部 -->
            <view class="combo-champion-row">
              <image wx:if="{{item.champion_icon}}" class="combo-champion-icon" src="{{item.champion_icon}}" mode="aspectFill" />
              <view wx:else class="combo-champion-icon combo-champion-icon-empty"></view>
              <view class="combo-champion-info">
                <text class="combo-champion-name">{{item.champion_name_zh || item.champion_id}}</text>
                <view class="combo-best-info">
                  <text class="combo-best-aug-name ellipsis">{{item.best_augment_name_zh || item.best_augment_id}}</text>
                  <text class="combo-best-winrate">胜率 {{item.best_win_rate}}</text>
                </view>
              </view>
            </view>

            <!-- 推荐海克斯 -->
            <view class="combo-subsection">
              <text class="combo-subsection-label">⚡ 推荐海克斯</text>
              <view class="combo-icon-row">
                <view wx:for="{{item.augments}}" wx:key="augment_id" wx:for-item="aug" class="combo-icon-item">
                  <image wx:if="{{aug.icon_url}}" class="combo-icon-sm" src="{{aug.icon_url}}" mode="aspectFill" />
                  <view wx:else class="combo-icon-sm combo-icon-empty"></view>
                  <text class="combo-icon-name ellipsis">{{aug.name_zh || aug.augment_id}}</text>
                  <text class="combo-icon-rate">{{aug.win_rate}}</text>
                </view>
                <view wx:if="{{item.augments.length === 0}}" class="combo-empty-hint">
                  <text class="text-xs text-placeholder">暂无数据</text>
                </view>
              </view>
            </view>

            <!-- 推荐装备 -->
            <view class="combo-subsection">
              <text class="combo-subsection-label">⚔️ 推荐装备</text>
              <view class="combo-icon-row">
                <view wx:for="{{item.items}}" wx:key="item_id" wx:for-item="it" class="combo-icon-item">
                  <image wx:if="{{it.icon_url}}" class="combo-icon-sm combo-item-icon" src="{{it.icon_url}}" mode="aspectFill" />
                  <view wx:else class="combo-icon-sm combo-icon-empty"></view>
                  <text class="combo-icon-name ellipsis">{{it.name_zh || it.item_id}}</text>
                  <text class="combo-icon-rate">{{it.win_rate}}</text>
                </view>
                <view wx:if="{{item.items.length === 0}}" class="combo-empty-hint">
                  <text class="text-xs text-placeholder">暂无数据</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 📋 免责说明 -->
    <view class="footer-disclaimer">
      <text class="disclaimer-text">数据来源自英雄联盟公开的第三方对局统计API</text>
      <text class="disclaimer-text">优化意见及商务合作请联系 flttzjc@hotmail.com</text>
    </view>

  </block>
</view>
