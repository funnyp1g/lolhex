<!--pages/index/index.wxml - 首页-->
<view class="page-index">
  <!-- 加载中 -->
  <loading-skeleton wx:if="{{loading}}" type="augment" count="{{4}}" />

  <!-- 错误状态 -->
  <view wx:elif="{{error}}" class="error-state">
    <van-empty description="数据加载失败" image="error">
      <van-button round type="danger" class="retry-btn" bindtap="onRetry">重新加载</van-button>
    </van-empty>
  </view>

  <!-- 加载完成 -->
  <block wx:elif="{{!loading}}">
    <!-- 🔍 搜索栏 -->
    <view class="home-search-wrap" bindtap="onSearchTap">
      <view class="home-search-inner">
        <text class="home-search-icon">🔍</text>
        <text class="home-search-placeholder">搜索英雄 / 海克斯...</text>
      </view>
    </view>

    <!-- 🏆 英雄强度排行 + ⚡ 海克斯排行（双栏） -->
    <view class="section">
      <view class="dual-panel">
        <!-- 左栏：英雄排行 -->
        <view class="dual-panel-item dual-panel-left">
          <view class="section-header">
            <text class="section-title">🏆 英雄排行</text>
            <text class="section-more" bindtap="onGoChampionList">全部 ›</text>
          </view>
          <view wx:if="{{champRankList.length === 0 && !champRankLoading}}" class="empty-mini">
            <text class="text-xs text-secondary">暂无数据</text>
          </view>
          <view wx:else class="mini-rank-list">
            <view
              wx:for="{{champRankList}}"
              wx:key="champion_id"
              class="mini-rank-item"
              data-champion-id="{{item.champion_id}}"
              bindtap="onMiniChampionTap"
            >
              <text class="mini-rank-index">{{index + 1}}</text>
              <image wx:if="{{item.icon_url}}" class="mini-rank-icon" src="{{item.icon_url}}" mode="aspectFill" />
              <view wx:else class="mini-rank-icon mini-rank-icon-empty"></view>
              <view class="mini-rank-info">
                <text class="mini-rank-name ellipsis">{{item.name_zh || item.name}}</text>
                <text class="mini-rank-winrate">{{item.win_rate}}%</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 右栏：海克斯排行 -->
        <view class="dual-panel-item dual-panel-right">
          <view class="section-header">
            <text class="section-title">⚡ 海克斯排行</text>
            <text class="section-more" bindtap="onGoAugmentList">全部 ›</text>
          </view>
          <view wx:if="{{augRankList.length === 0 && !augRankLoading}}" class="empty-mini">
            <text class="text-xs text-secondary">暂无数据</text>
          </view>
          <view wx:else class="mini-rank-list">
            <view
              wx:for="{{augRankList}}"
              wx:key="riot_id"
              class="mini-rank-item"
              data-id="{{item.riot_id || item._id}}"
              bindtap="onMiniAugmentTap"
            >
              <text class="mini-rank-index">{{index + 1}}</text>
              <image wx:if="{{item.icon_url}}" class="mini-rank-icon" src="{{item.icon_url}}" mode="aspectFill" />
              <view wx:else class="mini-rank-icon mini-rank-icon-empty"></view>
              <view class="mini-rank-info">
                <text class="mini-rank-name ellipsis">{{item.name_zh || item.name}}</text>
                <text class="mini-rank-winrate">{{item.win_rate}}%</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 更多资讯（hexdata 复刻） -->
    <view wx:if="{{funDataTopHexes.length > 0 || funDataHiddenGems.length > 0}}" class="section">
      <view class="section-header">
        <text class="section-title">更多资讯</text>
        <text class="section-subtitle">版本风向标 · 顶级海克斯 · 隐藏宝藏</text>
      </view>

      <!-- 版本风云 -->
      <view wx:if="{{funDataVersionWinners.length > 0 || funDataVersionLosers.length > 0}}" class="fun-card">
        <view class="fun-card-title">版本风云</view>
        <view class="version-grid">
          <view class="version-col">
            <view class="version-label version-label-up">版本赢家</view>
            <view wx:for="{{funDataVersionWinners}}" wx:key="championId" class="version-item"
                  data-champion-id="{{item.championId}}" bindtap="onVersionChampionTap">
              <image class="version-champ-icon" src="{{item.imageFull}}" mode="aspectFill" />
              <view class="version-info">
                <text class="version-champ-name">{{item.name}}</text>
                <text class="version-winrate">{{item.winRateDisplay}}%</text>
              </view>
              <text class="version-change version-change-up">{{item.changeDisplay}}%</text>
            </view>
          </view>
          <view class="version-col">
            <view class="version-label version-label-down">版本输家</view>
            <view wx:for="{{funDataVersionLosers}}" wx:key="championId" class="version-item"
                  data-champion-id="{{item.championId}}" bindtap="onVersionChampionTap">
              <image class="version-champ-icon" src="{{item.imageFull}}" mode="aspectFill" />
              <view class="version-info">
                <text class="version-champ-name">{{item.name}}</text>
                <text class="version-winrate">{{item.winRateDisplay}}%</text>
              </view>
              <text class="version-change version-change-down">{{item.changeDisplay}}%</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 顶级海克斯 -->
      <view wx:if="{{funDataTopHexes.length > 0}}" class="fun-card">
        <view class="fun-card-title">顶级海克斯</view>
        <view class="tophex-list">
          <view wx:for="{{funDataTopHexesDisplay}}" wx:key="id" class="tophex-item">
            <view class="tophex-header">
              <text class="tophex-rank">#{{index + 1}}</text>
              <text class="tophex-name">{{item.label}}</text>
              <view class="tophex-hex-badge" style="background:{{item.hexTierColor}}">
                <text>{{item.hexLabel}}</text>
              </view>
              <text class="tophex-meta">{{item.winRateDisplay}}% 胜率 · {{item.gamesDisplay}}场</text>
            </view>
            <view class="tophex-champions">
              <view wx:for="{{item.topChampions}}" wx:key="championId" wx:for-item="tc" class="tophex-champ"
                    data-champion-id="{{tc.championId}}" bindtap="onTopHexChampionTap">
                <image class="tophex-champ-icon" src="{{tc.imageFull}}" mode="aspectFill" />
                <text class="tophex-champ-name">{{tc.name}}</text>
                <text class="tophex-champ-winrate">{{tc.winRateDisplay}}%</text>
              </view>
            </view>
          </view>
        </view>
        <view wx:if="{{funDataTopHexes.length > 5}}" class="fun-expand-wrap">
          <view class="fun-expand-btn" bindtap="onToggleTopHexes">
            <text>{{topHexesExpandText}}</text>
            <text class="fun-expand-arrow {{topHexesExpanded ? 'expanded' : ''}}">▼</text>
          </view>
        </view>
      </view>

      <!-- 隐藏宝藏 -->
      <view wx:if="{{funDataHiddenGems.length > 0}}" class="fun-card">
        <view class="fun-card-title">隐藏宝藏<text class="fun-card-subtitle">（低选取、高胜率）</text></view>
        <view class="gem-list">
          <view wx:for="{{funDataHiddenGems}}" wx:key="augmentId" class="gem-item"
                data-augment-id="{{item.augmentId}}" bindtap="onHiddenGemTap">
            <image class="gem-icon" src="{{item.iconFull}}" mode="aspectFill" />
            <view class="gem-body">
              <text class="gem-name">{{item.name}}</text>
              <view class="gem-stats-row">
                <text class="gem-stat">{{item.gamesDisplay}}场</text>
                <text class="gem-stat-divider">|</text>
                <text class="gem-stat">选取 {{item.pickRateDisplay}}%</text>
                <text class="gem-stat-divider">|</text>
                <text class="gem-stat gem-stat-winrate">胜率 {{item.winRateDisplay}}%</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 📋 免责说明 -->
    <view class="footer-disclaimer">
      <text class="disclaimer-text">数据来源自英雄联盟公开的第三方对局统计API</text>
      <text class="disclaimer-text">优化意见及商务合作请联系 flttzjc@hotmail.com</text>
    </view>

  </block>
</view>
