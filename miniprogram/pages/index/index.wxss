/* pages/index/index.wxss - 首页样式 */
.page-index {
  padding: 20rpx 20rpx 160rpx;
  padding-bottom: 0;
  min-height: 100vh;
  background-color: var(--color-bg-page);
}


/* ===== 版本调整卡片 ===== */
.patch-card {
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #f0f5ff 0%, #ffffff 100%);
  border-radius: 16rpx;
  border: 1rpx solid rgba(24, 144, 255, 0.08);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.patch-card:active {
  background: linear-gradient(135deg, #e6f0ff, #fafafa);
}

.patch-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.patch-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
  flex-wrap: wrap;
}

.patch-title {
  font-size: 28rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  white-space: nowrap;
}

.patch-summary {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: nowrap;
  overflow: hidden;
}

.patch-summary-placeholder {
  font-size: 22rpx;
  color: var(--color-text-placeholder);
}

.patch-buff-count {
  font-size: 20rpx;
  color: var(--color-success);
  font-weight: var(--font-weight-medium);
  white-space: nowrap;
}

.patch-nerf-count {
  font-size: 20rpx;
  color: var(--color-error);
  font-weight: var(--font-weight-medium);
  white-space: nowrap;
}

.patch-right {
  display: flex;
  align-items: center;
  padding-left: var(--spacing-sm);
}

.expand-arrow {
  font-size: 20rpx;
  color: var(--color-text-placeholder);
  transition: transform var(--transition-base);
}

.expand-arrow.expanded {
  transform: rotate(180deg);
}

/* 版本调整详情 */
.patch-detail {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0,0,0,0.06);
}

.detail-group {
  margin-bottom: 16rpx;
}

.detail-group:last-child {
  margin-bottom: 0;
}

.detail-group-title {
  font-size: 24rpx;
  font-weight: var(--font-weight-bold);
  margin-bottom: 10rpx;
  padding-left: 4rpx;
}

.detail-group-title-buff {
  color: var(--color-success);
}

.detail-group-title-nerf {
  color: var(--color-error);
}

.detail-group-title-balance {
  color: var(--color-warning);
}

/* ===== 区块 ===== */
.section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  letter-spacing: 0.5rpx;
}

.section-more {
  font-size: 22rpx;
  color: #b0b0b0;
  padding: 4rpx 8rpx;
}

/* 空状态 */
.empty-state {
  padding: var(--spacing-xl) 0;
}

/* ===== 热门海克斯颁奖台 ===== */
.podium {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

/* 颁奖台舞台 */
.podium-stage {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 8rpx;
  padding: var(--spacing-md) var(--spacing-sm) 0;
}

/* 颁奖台每个位置 */
.podium-medal {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  border-radius: var(--radius-lg);
  padding: var(--spacing-md) var(--spacing-sm);
  background-color: var(--color-bg-card);
  box-shadow: var(--shadow-sm);
  transition: transform var(--transition-fast);
  position: relative;
}

.podium-medal:active {
  transform: scale(0.96);
}

/* 金牌 - 最高最大 */
.podium-medal-gold {
  order: 1;
  padding-top: var(--spacing-lg);
  padding-bottom: var(--spacing-lg);
  background: linear-gradient(180deg, #fff9e6, #ffffff);
  border: 2rpx solid #fadb14;
}

.podium-medal-gold .podium-medal-icon {
  width: 100rpx;
  height: 100rpx;
}

.podium-medal-gold .podium-medal-crown {
  font-size: 44rpx;
}

.podium-medal-gold .podium-medal-name {
  font-size: var(--font-size-sm);
}

.podium-medal-gold .podium-medal-step {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(180deg, #fadb14, #ffd666);
}

.podium-medal-gold .podium-medal-step-num {
  font-size: var(--font-size-lg);
}

/* 银牌 - 中间高度 */
.podium-medal-silver {
  order: 0;
  padding-top: var(--spacing-md);
  padding-bottom: calc(var(--spacing-md) + 24rpx);
  background: linear-gradient(180deg, #f0f0f0, #ffffff);
  border: 2rpx solid #d9d9d9;
}

.podium-medal-silver .podium-medal-icon {
  width: 84rpx;
  height: 84rpx;
}

.podium-medal-silver .podium-medal-crown {
  font-size: 36rpx;
}

.podium-medal-silver .podium-medal-name {
  font-size: var(--font-size-xs);
}

.podium-medal-silver .podium-medal-step {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(180deg, #d9d9d9, #f0f0f0);
}

/* 铜牌 - 最矮最小 */
.podium-medal-bronze {
  order: 2;
  padding-top: var(--spacing-md);
  padding-bottom: calc(var(--spacing-md) + 12rpx);
  background: linear-gradient(180deg, #fff0e6, #ffffff);
  border: 2rpx solid #ffc069;
}

.podium-medal-bronze .podium-medal-icon {
  width: 84rpx;
  height: 84rpx;
}

.podium-medal-bronze .podium-medal-crown {
  font-size: 36rpx;
}

.podium-medal-bronze .podium-medal-name {
  font-size: var(--font-size-xs);
}

.podium-medal-bronze .podium-medal-step {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(180deg, #ffc069, #ffe0b2);
}

/* 皇冠 */
.podium-medal-crown {
  position: absolute;
  top: -16rpx;
  left: 50%;
  transform: translateX(-50%);
  line-height: 1;
}

/* 图标 */
.podium-medal-icon {
  width: 84rpx;
  height: 84rpx;
  border-radius: var(--radius-md);
  background-color: var(--color-bg-page);
}

.podium-medal-icon-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  border-radius: var(--radius-md);
}

.podium-medal-icon-text {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: #fff;
}

/* 名称 */
.podium-medal-name {
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 140rpx;
}

/* 排名台阶 */
.podium-medal-step {
  width: 48rpx;
  height: 48rpx;
  border-radius: var(--radius-base);
  display: flex;
  align-items: center;
  justify-content: center;
}

.podium-medal-step-num {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
  color: #fff;
}

/* TOP4-5 普通卡片 */
.podium-bottom {
  display: flex;
  gap: var(--spacing-sm);
}

.podium-bottom-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: var(--spacing-sm);
  border-radius: var(--radius-lg);
  background-color: var(--color-bg-card);
  box-shadow: var(--shadow-sm);
  transition: background-color var(--transition-fast);
}

.podium-bottom-item:active {
  background-color: var(--color-bg-hover);
}

.podium-bottom-rank {
  font-size: var(--font-size-xs);
  color: var(--color-text-placeholder);
  font-weight: var(--font-weight-bold);
}

.podium-bottom-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-base);
  background-color: var(--color-bg-page);
}

.podium-bottom-icon-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  border-radius: var(--radius-base);
}

.podium-bottom-icon-text {
  font-size: 28rpx;
  font-weight: var(--font-weight-bold);
  color: #fff;
}

.podium-bottom-name {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 160rpx;
}

.podium-bottom-rate {
  font-size: var(--font-size-xs);
  color: var(--color-warning);
  font-weight: var(--font-weight-medium);
}

/* ===== 双栏排行 ===== */
.dual-panel {
  display: flex;
  gap: 12rpx;
}

.dual-panel-item {
  flex: 1;
  min-width: 0;
  background: var(--color-bg-card);
  border-radius: 16rpx;
  padding: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.dual-panel-item .section-header {
  margin-bottom: 8rpx;
}

.dual-panel-item .section-title {
  font-size: 26rpx;
}

.empty-mini {
  padding: 24rpx;
  text-align: center;
}

.mini-rank-list {
  display: flex;
  flex-direction: column;
}

.mini-rank-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 6rpx;
  border-radius: 8rpx;
  transition: background-color var(--transition-fast);
}

.mini-rank-item:active {
  background-color: var(--color-bg-hover);
}

.mini-rank-index {
  width: 28rpx;
  text-align: center;
  font-size: 22rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-text-placeholder);
  flex-shrink: 0;
}

.mini-rank-item:nth-child(1) .mini-rank-index { color: #f5a623; font-size: 24rpx; }
.mini-rank-item:nth-child(2) .mini-rank-index { color: #a0a0a0; font-size: 24rpx; }
.mini-rank-item:nth-child(3) .mini-rank-index { color: #d48806; font-size: 24rpx; }

.mini-rank-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #2a2a2e;
  flex-shrink: 0;
}

.mini-rank-icon-empty {
  background: var(--color-border);
}

.mini-rank-info {
  flex: 1;
  min-width: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.mini-rank-name {
  font-size: 24rpx;
  color: var(--color-text-primary);
  max-width: 110rpx;
}

.mini-rank-winrate {
  font-size: 22rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  flex-shrink: 0;
}

/* ===== 更多资讯（hexdata 复刻） ===== */
.section-subtitle {
  font-size: 22rpx;
  color: var(--color-text-placeholder);
}

.fun-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
}

.fun-card-title {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-md);
}

.fun-card-subtitle {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-normal);
  color: var(--color-text-placeholder);
}

/* ===== 版本风云 ===== */
.version-grid {
  display: flex;
  gap: 12rpx;
}

.version-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.version-label {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-bold);
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  text-align: center;
}

.version-label-up {
  background: rgba(5, 150, 105, 0.1);
  color: #059669;
}

.version-label-down {
  background: rgba(220, 38, 38, 0.1);
  color: #dc2626;
}

.version-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 8rpx;
  border-radius: var(--radius-base);
  background: var(--color-bg-page);
}

.version-item:active {
  background: var(--color-bg-hover);
}

.version-champ-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: var(--color-bg-page);
  flex-shrink: 0;
}

.version-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.version-champ-name {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.version-winrate {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.version-change {
  font-size: 24rpx;
  font-weight: var(--font-weight-bold);
  flex-shrink: 0;
}

.version-change-up {
  color: #059669;
}

.version-change-down {
  color: #dc2626;
}

/* ===== 顶级海克斯 ===== */
.tophex-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.tophex-item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 14rpx 12rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-md);
}

.tophex-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.tophex-rank {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  flex-shrink: 0;
  width: 32rpx;
}

.tophex-name {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  flex-shrink: 0;
}

.tophex-meta {
  font-size: 20rpx;
  color: var(--color-text-placeholder);
  margin-left: auto;
  flex-shrink: 0;
}

.tophex-hex-badge {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 56rpx;
  height: 34rpx;
}

.tophex-hex-badge text {
  font-size: 18rpx;
  font-weight: var(--font-weight-bold);
  color: #fff;
  line-height: 1;
}

.tophex-champions {
  display: flex;
  gap: 8rpx;
  overflow-x: auto;
  padding: 4rpx 0;
}

.tophex-champ {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  flex-shrink: 0;
  width: 80rpx;
  padding: 6rpx 4rpx;
  border-radius: 8rpx;
}

.tophex-champ:active {
  background: var(--color-bg-hover);
}

.tophex-champ-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--color-bg-page);
}

.tophex-champ-name {
  font-size: 18rpx;
  color: var(--color-text-primary);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 76rpx;
}

.tophex-champ-winrate {
  font-size: 18rpx;
  color: var(--color-warning);
  font-weight: var(--font-weight-medium);
}

.fun-expand-wrap {
  display: flex;
  justify-content: center;
  padding-top: var(--spacing-md);
}

.fun-expand-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  background: var(--color-bg-page);
  font-size: var(--font-size-sm);
  color: var(--color-primary);
}

.fun-expand-btn:active {
  background: var(--color-bg-hover);
}

.fun-expand-arrow {
  font-size: var(--font-size-xs);
  transition: transform var(--transition-base);
}

.fun-expand-arrow.expanded {
  transform: rotate(180deg);
}

/* ===== 隐藏宝藏 ===== */
.gem-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.gem-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx 14rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg-page);
}

.gem-item:active {
  background: var(--color-bg-hover);
}

.gem-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-base);
  background: #2a2a2e;
  flex-shrink: 0;
}

.gem-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.gem-name {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}

.gem-stats-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.gem-stat {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.gem-stat-divider {
  font-size: 18rpx;
  color: var(--color-border);
}

.gem-stat-winrate {
  color: var(--color-warning);
  font-weight: var(--font-weight-medium);
}

/* ===== 首页搜索栏 ===== */
.home-search-wrap {
  margin-bottom: 24rpx;
}

.home-search-inner {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 28rpx;
  border-radius: 40rpx;
  background: var(--color-bg-card);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s;
}

.home-search-inner:active {
  background: var(--color-bg-hover);
  transform: scale(0.99);
}

.home-search-icon {
  font-size: 28rpx;
}

.home-search-placeholder {
  font-size: 26rpx;
  color: #b0b0b0;
}

.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 快速入口 ===== */
.quick-entries {
  display: flex;
  justify-content: space-around;
  padding: var(--spacing-md) 0;
}

.quick-entry {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-xs);
  padding: var(--spacing-md) var(--spacing-lg);
  border-radius: var(--radius-lg);
  background-color: var(--color-bg-card);
  box-shadow: var(--shadow-sm);
  min-width: 150rpx;
  transition: background-color var(--transition-fast);
}

.quick-entry:active {
  background-color: var(--color-bg-hover);
}

.quick-icon {
  font-size: 56rpx;
}

.quick-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
}

/* ===== 错误状态 ===== */
.error-state {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 50vh;
}

.retry-btn {
  margin-top: var(--spacing-md);
}

/* ===== 底部免责说明 ===== */
.footer-disclaimer {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 36rpx 32rpx 48rpx;
  margin-top: 16rpx;
}

.disclaimer-text {
  font-size: 20rpx;
  color: #8c8c8c;
  text-align: center;
  line-height: 1.5;
}
