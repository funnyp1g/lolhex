/* components/augment-card/augment-card.wxss - 海克斯卡片样式 */
.aug-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  position: relative;
  transition: background-color var(--transition-fast);
}

.aug-card:active {
  background-color: var(--color-bg-hover);
}

/* 排名序号角标 */
.aug-rank {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-bold);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

/* 顶部布局：图标 + 信息 + Tier */
.aug-header {
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-md);
}

.aug-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-base);
  background-color: var(--color-bg-page);
  flex-shrink: 0;
}

/* 排名奖牌 emoji（TOP3） */
.aug-rank-medal {
  background: transparent;
  border: none;
  font-size: 40rpx;
  line-height: 1;
}

/* 海克斯图标占位符 */
.aug-icon-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-base);
}

.aug-icon-placeholder-text {
  font-size: 28rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-text-placeholder);
}

.aug-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.aug-title-row {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.aug-name {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 稀有度标签 */
.aug-rarity {
  display: inline-block;
  padding: 2rpx 10rpx;
  border-radius: var(--radius-round);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  flex-shrink: 0;
}

.rarity-prismatic {
  color: var(--color-prismatic);
  background-color: var(--color-prismatic-bg);
}

.rarity-gold {
  color: var(--color-gold);
  background-color: var(--color-gold-bg);
}

.rarity-silver {
  color: var(--color-silver);
  background-color: var(--color-silver-bg);
}

/* 描述 */
.aug-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 统计行 */
.aug-stats {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  margin-top: 8rpx;
}

.aug-stat {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.aug-winrate {
  color: var(--color-warning);
  font-weight: var(--font-weight-medium);
}

.aug-pickrate {
  color: var(--color-primary);
}

/* 胜率进度条区域 */
.aug-rate-wrap {
  margin-top: var(--spacing-sm);
}
