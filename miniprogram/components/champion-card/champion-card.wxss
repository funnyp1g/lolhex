/* components/champion-card/champion-card.wxss - 英雄卡片样式 */
.champ-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  position: relative;
  transition: background-color var(--transition-fast);
}

.champ-card:active {
  background-color: var(--color-bg-hover);
}

/* ===== 列表模式 ===== */
.champ-list {
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-md);
}

/* 排名角标 */
.champ-rank {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-bold);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.champ-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-lg);
  background-color: var(--color-bg-page);
  flex-shrink: 0;
}

.champ-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.champ-title-row {
  display: flex;
  align-items: baseline;
  gap: var(--spacing-sm);
}

.champ-name {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.champ-title-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-placeholder);
  flex-shrink: 0;
}

.champ-roles {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.champ-role-tag {
  padding: 2rpx 14rpx;
  border-radius: var(--radius-round);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
}

.champ-stats-row {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  margin-top: 8rpx;
}

.champ-stat-winrate {
  font-size: var(--font-size-xs);
  color: var(--color-warning);
  font-weight: var(--font-weight-medium);
}

.champ-stat-pickrate {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
}

/* 列表模式行布局：T级徽章 + 头像 + 信息 */
.champion-list-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

/* ===== 网格模式 ===== */
.champ-grid {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-xs);
  margin-bottom: var(--spacing-sm);
  border-radius: var(--radius-md);
}

.champ-grid-avatar-wrap {
  position: relative;
  margin-bottom: var(--spacing-xs);
}

.champ-grid-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-lg);
  background-color: var(--color-bg-page);
}

.champ-grid-tier {
  position: absolute;
  bottom: -6rpx;
  right: -6rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  font-size: 18rpx;
  font-weight: var(--font-weight-bold);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #fff;
}

.champ-grid-name {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.champ-grid-rate {
  font-size: var(--font-size-xs);
  color: var(--color-warning);
  font-weight: var(--font-weight-medium);
  margin-top: 4rpx;
}
