<!--components/champion-card/champion-card.wxml - 英雄卡片-->

<!-- 列表模式 -->
<view wx:if="{{mode === 'list'}}" class="champ-card champ-list" bindtap="onTap">
  <!-- 排名角标 -->
  <text wx:if="{{rank > 0}}" class="champ-rank">{{rank}}</text>
  <!-- 英雄头像 -->
  <image wx:if="{{champion.icon_url}}" class="champ-avatar" src="{{champion.icon_url}}" mode="aspectFill" />
  <!-- 信息区 -->
  <view class="champ-body">
    <view class="champ-title-row">
      <!-- T级徽章（列表模式左侧） -->
      <tier-badge
        wx:if="{{showTierRank && (champion.tier_rank || tierRank)}}"
        tier="{{champion.tier_rank || tierRank}}"
        mode="T"
        size="small"
      />
      <text class="champ-name">{{champion.name_zh}}</text>
      <text class="champ-title-text">{{champion.title}}</text>
    </view>
    <!-- 角色标签 -->
    <view class="champ-roles">
      <view wx:for="{{champion.roles}}" wx:key="*this"
        class="champ-role-tag"
        style="color: {{roleColors[item] || '#1890ff'}}; background-color: {{roleColors[item] || '#1890ff'}}1a;">
        {{item}}
      </view>
    </view>
    <!-- 统计行 -->
    <view wx:if="{{showStats}}" class="champ-stats-row">
      <text wx:if="{{hasWinRate}}" class="champ-stat-winrate">
        胜率 {{winRateDisplay}}
      </text>
      <text wx:if="{{hasPickRate}}" class="champ-stat-pickrate">
        选取 {{pickRateDisplay}}
      </text>
    </view>
  </view>
  <!-- Tier 徽章 -->
  <tier-badge wx:if="{{showTier && champion.tier}}" tier="{{champion.tier}}" size="normal" />
</view>

<!-- 网格模式 -->
<view wx:elif="{{mode === 'grid'}}" class="champ-card champ-grid" bindtap="onTap">
  <view class="champ-grid-avatar-wrap">
    <image wx:if="{{champion.icon_url}}" class="champ-grid-avatar" src="{{champion.icon_url}}" mode="aspectFill" />
    <text wx:if="{{showTier && champion.tier}}" class="champ-grid-tier">
      {{champion.tier}}
    </text>
  </view>
  <text class="champ-grid-name">{{champion.name_zh}}</text>
  <view wx:if="{{showStats && hasWinRate}}" class="champ-grid-rate">
    {{winRateDisplay}}
  </view>
</view>
