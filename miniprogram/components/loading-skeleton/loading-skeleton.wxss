/* components/loading-skeleton/loading-skeleton.wxss - 骨架屏样式 */
.sk-wrap {
  padding: 0;
}

/* 基础骨架元素 */
.sk-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-md);
}

.sk-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-lg);
  background-color: var(--color-bg-hover);
  flex-shrink: 0;
}

.sk-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.sk-line {
  background-color: var(--color-bg-hover);
  border-radius: var(--radius-base);
  height: 28rpx;
}

.sk-title {
  height: 36rpx;
  width: 60%;
}

.sk-row {
  width: 100%;
}

.sk-row-short {
  width: 40%;
}

/* 宽度辅助类 */
.sk-w-20 { width: 20%; }
.sk-w-25 { width: 25%; }
.sk-w-30 { width: 30%; }
.sk-w-40 { width: 40%; }
.sk-w-45 { width: 45%; }
.sk-w-50 { width: 50%; }
.sk-w-60 { width: 60%; }

/* Tier 占位 */
.sk-tier {
  width: 48rpx;
  height: 40rpx;
  border-radius: var(--radius-base);
  background-color: var(--color-bg-hover);
  flex-shrink: 0;
}

/* ===== 英雄骨架 ===== */
.sk-champ-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-lg);
  background-color: var(--color-bg-hover);
  flex-shrink: 0;
}

/* ===== 海克斯骨架 ===== */
.sk-aug-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-base);
  background-color: var(--color-bg-hover);
  flex-shrink: 0;
}

.sk-bar {
  height: 12rpx;
  width: 100%;
  border-radius: var(--radius-round);
  margin-top: 4rpx;
}

/* ===== 装备骨架 ===== */
.sk-item-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-base);
  background-color: var(--color-bg-hover);
  flex-shrink: 0;
}

.sk-item-card {
  /* 复用 sk-card 样式 */
}

/* ===== 详情页骨架 ===== */
.sk-detail {
  padding: var(--spacing-md);
}

.sk-detail-header {
  display: flex;
  gap: var(--spacing-md);
  margin-bottom: var(--spacing-lg);
}

.sk-detail-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-lg);
  background-color: var(--color-bg-hover);
  flex-shrink: 0;
}

.sk-detail-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
  justify-content: center;
}

.sk-tags {
  display: flex;
  gap: var(--spacing-sm);
  margin-top: 8rpx;
}

.sk-tag {
  width: 80rpx;
  height: 36rpx;
  border-radius: var(--radius-round);
  background-color: var(--color-bg-hover);
}

.sk-stats-row {
  display: flex;
  gap: var(--spacing-md);
  margin-bottom: var(--spacing-lg);
}

.sk-stat-box {
  flex: 1;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ===== 脉冲动画 ===== */
.sk-animated .sk-avatar,
.sk-animated .sk-champ-avatar,
.sk-animated .sk-aug-icon,
.sk-animated .sk-item-icon,
.sk-animated .sk-line,
.sk-animated .sk-tier,
.sk-animated .sk-tag,
.sk-animated .sk-detail-avatar,
.sk-animated .sk-stat-box {
  animation: skeleton-pulse 1.5s ease-in-out infinite;
}

@keyframes skeleton-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}
